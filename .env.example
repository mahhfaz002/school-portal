APP_NAME="School Portal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# In production (Laravel Cloud) set: APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-app.laravel.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev uses SQLite (zero-config). On Laravel Cloud, attach a managed
# MySQL/Postgres database and Cloud injects these vars automatically.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=school_portal
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# Local: "public" (run php artisan storage:link). Production: "s3" for persistent uploads.
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Email: "log" writes mails to storage/logs (dev). For real emails use SMTP.
# Example for Brevo/Mailtrap/Gmail/Resend-SMTP — fill from your provider:
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="no-reply@yourschool.edu"
MAIL_FROM_NAME="${APP_NAME}"

# Object storage (S3-compatible) for persistent uploads in production.
# On Laravel Cloud, attach object storage and it injects these automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# AWS_URL=            # public base URL of the bucket (set if not auto-derived)
# AWS_ENDPOINT=       # for non-AWS S3 (Cloudflare R2, MinIO, etc.)

VITE_APP_NAME="${APP_NAME}"
